rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USERS ────────────────────────────────────────────
    match /users/{uid} {
      // Users can only read/write their own document
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.keys().hasAll(['displayName', 'isAgeVerified'])
                    && request.resource.data.isAgeVerified == true;
      allow update: if request.auth != null && request.auth.uid == uid
                    // Prevent changing auth-related fields
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'createdAt']);

      // ─── JOURNAL ENTRIES ──────────────────────────────
      match /journal/{entryId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.keys().hasAll(['productName', 'rating', 'createdAt'])
                      && request.resource.data.rating >= 1
                      && request.resource.data.rating <= 5;
        allow update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // ─── CROSS-CATEGORY (D5 — cross-category graph) ───
      match /cross_category/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid
                     && request.resource.data.categories is list;
      }

      // ─── PRE-QUIZ SEED (D8 — discovery sequences) ─────
      match /pre_quiz_seed/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid
                     && request.resource.data.productIds is list;
      }

      // ─── AROMA CALIBRATION (D3) ───────────────────────
      match /aroma_calibration/{sessionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.keys().hasAll(['sessionId', 'responses']);
        allow update, delete: if false;
      }

      // ─── FRIENDS (S5.2 friend graph) ──────────────────
      match /friends/{friendUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid
                     && (
                          (request.method == 'delete')
                          ||
                          (request.resource.data.uid == friendUid
                           && request.resource.data.followedAt is string)
                        );
      }

      // ─── GAMIFICATION STATE ───────────────────────────
      match /gamification/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        // Only Cloud Functions should write gamification state
        // to prevent XP cheating. But for Phase 1 (no cloud functions),
        // allow client writes with validation.
        allow write: if request.auth != null && request.auth.uid == uid
                     && request.resource.data.xp >= 0
                     && request.resource.data.level >= 0
                     && request.resource.data.level <= 3
                     && request.resource.data.streak >= 0;
      }
    }

    // ─── PRODUCTS (read-only, seeded by admin) ──────────
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── DISHES (read-only, seeded by admin) ─────────────
    match /dishes/{dishId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── COMMUNITY SIGNALS (Bro Circle counters) ─────────
    // Public aggregates written by CF-11 (admin only). Any signed-in
    // user can read for the Bro Circle on Home.
    match /community_signals/{productId} {
      allow read: if request.auth != null;
      allow write: if false; // CF-11 admin SDK only
    }

    // ─── PHONE INDEX (S5.2 friend discovery) ─────────────
    // Hash → uid lookup. Each user writes their OWN hash on sign-in.
    // Reads are restricted to whereIn batches (caps brute-force scan).
    // The hash is sha256(E.164 phone) — irreversible without the
    // original number.
    match /phone_index/{hash} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.uid == request.auth.uid;
    }

    // ─── PAIRING FEEDBACK (D6 — pairing success rate) ────
    // Per-user response to "Did Bro get it right?". Each user
    // owns docs whose id is `{uid}_{entryId}`; ownership enforced
    // via the userId field. Only the user can read their feedback;
    // CF-09/engine read via Admin SDK. Aggregates are append-only
    // counter docs maintained client-side via transaction.
    match /pairing_feedback/{feedbackId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
                            && request.resource.data.userId == request.auth.uid
                            && request.resource.data.response in ['yes', 'maybe', 'no'];
      allow delete: if false;
    }

    match /pairing_aggregates/{aggregateId} {
      // Aggregates are world-readable by signed-in users — they feed
      // engine v1.1 ranking shown to every user. Writes constrained
      // to non-negative monotonic counters; no userId field, so any
      // signed-in user may bump (transactional logic in client +
      // server-side validator in CF-02 for anti-cheat in Sprint 3).
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.yes >= 0
                   && request.resource.data.maybe >= 0
                   && request.resource.data.no >= 0;
    }

    // ─── DENY ALL OTHER PATHS ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
