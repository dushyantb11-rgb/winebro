rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USERS ────────────────────────────────────────────
    match /users/{uid} {
      // Users can only read/write their own document
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.keys().hasAll(['displayName', 'isAgeVerified'])
                    && request.resource.data.isAgeVerified == true;
      allow update: if request.auth != null && request.auth.uid == uid
                    // Prevent changing auth-related fields
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'createdAt']);

      // ─── JOURNAL ENTRIES ──────────────────────────────
      match /journal/{entryId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.keys().hasAll(['productName', 'rating', 'createdAt'])
                      && request.resource.data.rating >= 1
                      && request.resource.data.rating <= 5;
        allow update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // ─── GAMIFICATION STATE ───────────────────────────
      match /gamification/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        // Only Cloud Functions should write gamification state
        // to prevent XP cheating. But for Phase 1 (no cloud functions),
        // allow client writes with validation.
        allow write: if request.auth != null && request.auth.uid == uid
                     && request.resource.data.xp >= 0
                     && request.resource.data.level >= 0
                     && request.resource.data.level <= 3
                     && request.resource.data.streak >= 0;
      }
    }

    // ─── PRODUCTS (read-only, seeded by admin) ──────────
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── DISHES (read-only, seeded by admin) ─────────────
    match /dishes/{dishId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── DENY ALL OTHER PATHS ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
