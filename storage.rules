rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ─── BROCARD MEDIA (per-user, multiple slots) ──────────
    // Photos: bottle.jpg | label.jpg — image/jpeg or image/png, <8MB.
    // Voice : notes.m4a — audio/mp4 (AAC), <16MB.
    // Owner-only read + write.
    match /users/{uid}/brocard/{entryId}/{file} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
                   && (
                        (request.resource.size < 8 * 1024 * 1024
                         && request.resource.contentType.matches('image/(jpeg|png)'))
                        ||
                        (request.resource.size < 16 * 1024 * 1024
                         && request.resource.contentType.matches('audio/.*'))
                      );
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
