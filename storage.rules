rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ─── BROCARD PHOTOS (per-user, write-once-per-slot) ────
    // Two slots: bottle | label. Files capped at 8MB and must be
    // image/jpeg or image/png. Owner-only read + write.
    match /users/{uid}/brocard/{entryId}/{file} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
